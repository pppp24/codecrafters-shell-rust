#!/usr/bin/env expect
#
# Regression suite for the raw-mode line editor + builtin completion (Layer 5).
#
# Runs the shell under a pseudo-terminal, exercising the interactive raw-mode
# path (termios raw mode, byte loop, echo, Backspace, escape swallowing, Tab
# completion) — which piped stdin cannot reach.
#
# Teardown — `close` then `wait`, in that order:
#   `spawn` allocates a pty; the master fd is held by THIS expect process, not
#   the child. Killing the child (`kill` + `wait`) reaps the process but leaks
#   the master fd, so the pty device stays allocated — do that per test and
#   the system-wide pty pool exhausts, hanging a later `spawn`.
#   `close` releases the master fd (and sends the child EOF, so it exits on
#   its own); `wait` then reaps it. close-before-wait, with no prior kill, is
#   the order that frees the pty cleanly.
#
# No settle sleeps: the shell prints its prompt only AFTER entering raw mode
# (layer_5 decision #7), so matching a prompt guarantees raw mode is engaged
# and the next keystrokes won't be lost to raw-mode entry's TCSAFLUSH.
#
# Usage:    cargo build && expect tests/line_editor.exp   (run from anywhere)
# Install:  brew install expect
#
# Exit code: 0 if all pass, 1 if any fail, 2 on a harness error.

cd [file join [file dirname [info script]] ..]

# Absolute path so tests that `cd` into a tempdir (filename completion)
# can still spawn the binary.
set SHELL_BIN [file normalize "./target/debug/codecrafters-shell"]
set timeout 5
log_user 0

set passed 0
set failed 0

proc pass {name} {
    global passed
    incr passed
    puts "  ok   - $name"
    flush stdout
}

proc fail {name why} {
    global failed
    incr failed
    puts "  FAIL - $name  ($why)"
    flush stdout
}

# Spawn a fresh shell and sync on the first prompt.
# `spawn_id` must be global — otherwise `spawn` sets a proc-local copy that
# vanishes on return, leaving send/expect/close bound to the wrong terminal.
proc boot {} {
    global SHELL_BIN spawn_id
    spawn $SHELL_BIN
    expect {
        -ex {$ } {}
        timeout  { puts "FATAL: shell printed no startup prompt"; exit 2 }
        eof      { puts "FATAL: shell exited before prompting";   exit 2 }
    }
}

# Per-test teardown. `close` releases the pty master fd held by this expect
# process (this is what prevents pty-pool exhaustion) and sends the shell EOF
# so it exits; `wait` reaps it. No `kill` — killing first lets expect reset
# spawn_id before close runs, so close would hit the wrong channel.
proc shutdown {} {
    global spawn_id
    catch { close }
    catch { wait }
}

if {![file exists $SHELL_BIN]} {
    puts "FATAL: $SHELL_BIN not found — run `cargo build` first"
    exit 2
}

# The shell inherits this directory as its cwd, so `pwd` output equals [pwd];
# used as a marker that a command actually executed.
set cwd [pwd]

# Force an empty PATH for the default case so completion only considers
# builtins. Without this, prefixes like 'ex' / 'pw' / 'c' collide with the
# host's /bin and /usr/bin (export, pwgen, cat, ...) and become multi-match.
# The PATH-completion test below sets PATH locally for its own scope.
# `orig_path` keeps the host PATH around so Tcl's own `exec mktemp` etc. work
# when we need them.
set orig_path $::env(PATH)
set ::env(PATH) ""

puts "running line-editor regression suite\n"

# --- completion: a unique prefix completes ----------------------------------

boot
send "ech\t"
expect {
    -ex "echo " { pass "completion: 'ech' + Tab -> 'echo '" }
    timeout     { fail "completion: 'ech' + Tab -> 'echo '" "no completion appeared" }
}
shutdown

boot
send "ex\t"
expect {
    -ex "exit " { pass "completion: 'ex' + Tab -> 'exit '" }
    timeout     { fail "completion: 'ex' + Tab -> 'exit '" "no completion appeared" }
}
shutdown

boot
send "typ\t"
expect {
    -ex "type " { pass "completion: 'typ' + Tab -> 'type '" }
    timeout     { fail "completion: 'typ' + Tab -> 'type '" "no completion appeared" }
}
shutdown

boot
send "pw\t"
expect {
    -ex "pwd " { pass "completion: 'pw' + Tab -> 'pwd '" }
    timeout    { fail "completion: 'pw' + Tab -> 'pwd '" "no completion appeared" }
}
shutdown

boot
send "c\t"
expect {
    -ex "cd " { pass "completion: 'c' + Tab -> 'cd ' (unique prefix)" }
    timeout   { fail "completion: 'c' + Tab -> 'cd '" "no completion appeared" }
}
shutdown

# An already-complete builtin name + Tab still appends the trailing space.
boot
send "echo\t"
expect {
    -ex "echo " { pass "completion: exact 'echo' + Tab -> 'echo ' (adds space)" }
    timeout     { fail "completion: exact 'echo' + Tab" "no trailing space appended" }
}
shutdown

# --- completion produces a runnable command ---------------------------------

boot
send "pw\t\r"
expect {
    -ex $cwd { pass "completion: 'pw' + Tab + Enter executes pwd" }
    timeout  { fail "completion: 'pw' + Tab + Enter executes pwd" "pwd output not seen" }
}
shutdown

# --- ambiguous / no-match: the buffer is left untouched ---------------------
# Complete-then-run: the command that runs must be exactly what was typed.
# If Tab had mutated the buffer, a different command (or none) would run.

boot
send "e\t\r"
expect {
    -ex "e: command not found" { pass "completion: ambiguous 'e' + Tab leaves buffer = 'e'" }
    timeout { fail "completion: ambiguous 'e' + Tab" "buffer altered or no error seen" }
}
shutdown

boot
send "xyz\t\r"
expect {
    -ex "xyz: command not found" { pass "completion: no-match 'xyz' + Tab leaves buffer = 'xyz'" }
    timeout { fail "completion: no-match 'xyz' + Tab" "buffer altered or no error seen" }
}
shutdown

# --- multi-match: two-Tab listing (layer 7) ---------------------------------
# Prefix 'e' matches the builtins 'echo' and 'exit'. First Tab should ring
# the bell; the immediately-following second Tab should list both candidates
# alphabetically with a two-space separator, then redraw `$ e` so the user
# can keep typing. Three assertions on one fixture.

boot
send "e\t"
expect {
    -ex "\x07" { pass "multi-match: first Tab rings the bell" }
    timeout    { fail "multi-match: first Tab rings the bell" "no bell character seen" }
}
send "\t"
expect {
    -ex "echo  exit" { pass "multi-match: second Tab lists candidates two-space-separated" }
    timeout          { fail "multi-match: second Tab lists candidates" "candidate listing not seen" }
}
expect {
    -ex {$ e} { pass "multi-match: prompt + buffer redrawn after listing" }
    timeout   { fail "multi-match: prompt + buffer redrawn after listing" "redraw not seen" }
}
shutdown

# A keystroke between Tabs must reset the Tab-count so the next Tab is treated
# as a fresh first Tab — not a listing. After 'e<Tab>q<Tab>', the buffer is
# 'eq' (no match → bell), and crucially must NOT trigger the {echo,exit}
# listing left over from the first Tab.

boot
send "e\tq\t"
set saw_listing 0
set timeout 1
expect {
    -ex "echo  exit" { set saw_listing 1 }
    timeout {}
}
set timeout 5
if {$saw_listing} {
    fail "multi-match: keystroke between Tabs resets state" "stale Tab-count produced a stray listing"
} else {
    pass "multi-match: keystroke between Tabs resets state (no stray listing)"
}
shutdown

# --- LCP partial completion (layer 8) ---------------------------------------
# Mirrors the codecrafters LCP contract: PATH contains three executables
# where each is a prefix of the next. Progressive Tab completion:
#   xyz_<TAB>           -> xyz_foo            (LCP of all three; no space)
#   xyz_foo_<TAB>       -> xyz_foo_bar        (LCP of remaining two; no space)
#   xyz_foo_bar_<TAB>   -> xyz_foo_bar_baz    (single match; WITH space)
# The user types '_' between Tabs (per the codecrafters spec).

set ::env(PATH) $orig_path
set tmp [exec mktemp -d]
exec touch "$tmp/xyz_foo" "$tmp/xyz_foo_bar" "$tmp/xyz_foo_bar_baz"
exec chmod +x "$tmp/xyz_foo" "$tmp/xyz_foo_bar" "$tmp/xyz_foo_bar_baz"
set ::env(PATH) $tmp

boot
send "xyz_\t"
# Step 1: user types 'xyz_' (echoed) then Tab; shell appends LCP suffix 'foo'.
# Stream so far: 'xyz_' + 'foo' = 'xyz_foo'.
expect {
    -ex "xyz_foo" { pass "LCP step 1: 'xyz_' + Tab -> 'xyz_foo' (no trailing space)" }
    timeout       { fail "LCP step 1" "did not extend to xyz_foo" }
}
send "_\t"
# Step 2: '_' is echoed, then Tab extends the LCP further by 'bar'.
# expect matches against the UNCONSUMED stream, so the new bytes are '_bar',
# not the cumulative 'xyz_foo_bar'.
expect {
    -ex "_bar" { pass "LCP step 2: '_' + Tab -> '_bar' (no trailing space)" }
    timeout    { fail "LCP step 2" "did not extend by '_bar'" }
}
send "_\t"
# Step 3: '_' echoed, single match -> completion adds 'baz' + trailing space.
# New bytes: '_baz '. The trailing space is the contract this layer must meet.
expect {
    -ex "_baz " { pass "LCP step 3: '_' + Tab -> '_baz ' (single match, trailing space)" }
    timeout    { fail "LCP step 3" "did not complete with trailing space" }
}
shutdown

# Edge case: after an LCP extension leaves the prefix at the stuck length
# (LCP == prefix), pressing Tab again must follow the layer 7 path —
# bell on the next Tab, list on the one after — not silently extend.
# Buffer: 'xyz_foo' (after step 1). Press Tab: LCP=='xyz_foo' (stuck),
# so the bell-then-list dance kicks in.

boot
send "xyz_\t"
expect {
    -ex "xyz_foo" {}
    timeout       { fail "LCP edge setup" "step 1 didn't extend"; shutdown; continue }
}
send "\t"
expect {
    -ex "\x07" { pass "LCP stuck: Tab on extended prefix rings bell (matches bash default)" }
    timeout    { fail "LCP stuck: bell on Tab after extension" "no bell character seen" }
}
send "\t"
expect {
    -ex "xyz_foo  xyz_foo_bar  xyz_foo_bar_baz" {
        pass "LCP stuck: second Tab after extension lists all candidates"
    }
    timeout {
        fail "LCP stuck: listing after second Tab" "candidate listing not seen"
    }
}
shutdown

set ::env(PATH) $orig_path
exec rm -rf $tmp
set ::env(PATH) ""

# --- filename completion (layer 9) ------------------------------------------
# Tab on an argument (text after a space) completes filenames from cwd.
# Spawn the shell with cwd set to a tempdir containing the test files; the
# shell calls env::current_dir() at Tab time, so its view of cwd is whatever
# Tcl's cwd was at the moment of `spawn`.

set ::env(PATH) $orig_path
set tmp [exec mktemp -d]
exec touch "$tmp/readme.txt" "$tmp/hello_world.py"
set ::env(PATH) ""

set saved_cwd [pwd]
cd $tmp

# Codecrafters scenario 1: 'cat re' + Tab -> 'cat readme.txt '
boot
send "cat re\t"
expect {
    -ex "adme.txt " { pass "filename: 'cat re' + Tab -> 'cat readme.txt ' (trailing space)" }
    timeout         { fail "filename: 'cat re'" "completion suffix not seen" }
}
shutdown

# Codecrafters scenario 2: 'cat hello' + Tab -> 'cat hello_world.py '
boot
send "cat hello\t"
expect {
    -ex "_world.py " { pass "filename: 'cat hello' + Tab -> 'cat hello_world.py ' (trailing space)" }
    timeout          { fail "filename: 'cat hello'" "completion suffix not seen" }
}
shutdown

# Non-existent command word — argument completion still fires.
boot
send "xyz read\t"
expect {
    -ex "me.txt " { pass "filename: 'xyz read' + Tab completes the arg regardless of command validity" }
    timeout       { fail "filename: 'xyz read'" "completion suffix not seen" }
}
shutdown

cd $saved_cwd
set ::env(PATH) $orig_path
exec rm -rf $tmp
set ::env(PATH) ""

# --- nested-path completion (layer 10) --------------------------------------
# Tab on an argument that contains a '/'. The shell splits at the last slash:
# everything up to it is the directory (relative to cwd), everything after
# is the filename prefix. The buffer's path-part stays put; only the missing
# filename suffix is appended, plus a trailing space.

set ::env(PATH) $orig_path
set tmp [exec mktemp -d]
exec mkdir -p "$tmp/path/to"
exec touch "$tmp/path/to/file.txt"
set ::env(PATH) ""

set saved_cwd [pwd]
cd $tmp

# Codecrafters scenario: 'cat path/to/f' + Tab -> 'cat path/to/file.txt '
boot
send "cat path/to/f\t"
expect {
    -ex "ile.txt " { pass "nested: 'cat path/to/f' + Tab -> 'cat path/to/file.txt ' (trailing space)" }
    timeout        { fail "nested: 'cat path/to/f'" "completion suffix not seen" }
}
shutdown

cd $saved_cwd
set ::env(PATH) $orig_path
exec rm -rf $tmp
set ::env(PATH) ""

# --- directory completion: trailing '/' marker (layer 11) -------------------
# A directory match completes with a '/' suffix and NO trailing space, so the
# next Tab is treated as path completion (segment contains '/' → layer-10
# dispatch descends). The codecrafters scenario:
#   $ ls <TAB>          ->  $ ls pig/
#   $ ls pig/<TAB>      ->  $ ls pig/dog/
# Step 2 doubles as the "no trailing space" assertion: if a space had been
# appended after 'pig/', the second Tab's rfind(' ') would find that space,
# segment would be "", and we'd dispatch into cwd-filename completion (which
# would find nothing matching) → bell instead of descent.

set ::env(PATH) $orig_path
set tmp [exec mktemp -d]
exec mkdir -p "$tmp/pig/dog"
set ::env(PATH) ""

set saved_cwd [pwd]
cd $tmp

boot
send "ls \t"
expect {
    -ex "pig/" { pass "dir-completion: 'ls ' + Tab -> 'ls pig/' (slash, no trailing space)" }
    timeout    { fail "dir-completion: step 1" "directory completion not seen" }
}
send "\t"
expect {
    -ex "dog/" { pass "dir-completion: second Tab on 'ls pig/' descends into 'pig/dog/'" }
    timeout    { fail "dir-completion: step 2" "nested directory completion not seen (likely a stray trailing space after 'pig/')" }
}
shutdown

cd $saved_cwd
set ::env(PATH) $orig_path
exec rm -rf $tmp
set ::env(PATH) ""

# --- Backspace edits the buffer ---------------------------------------------
# 'pwdX' + Backspace -> 'pwd'; pwd runs only if the X was actually removed.

boot
send "pwdX\x7f\r"
expect {
    -ex $cwd { pass "backspace: 'pwdX' + BS + Enter corrects buffer to 'pwd'" }
    timeout  { fail "backspace: 'pwdX' + BS + Enter" "buffer not corrected to 'pwd'" }
}
shutdown

# --- a plain, un-completed builtin still runs -------------------------------

boot
send "type echo\r"
expect {
    -ex "echo is a shell builtin" { pass "plain command: 'type echo' executes" }
    timeout { fail "plain command: 'type echo' executes" "expected output not seen" }
}
shutdown

# --- an arrow-key escape sequence is swallowed, not injected ----------------
# Up-arrow (ESC [ A) then 'pwd': if the sequence leaked, the buffer would be
# '[Apwd' and pwd would not run.

boot
send "\x1b\[Apwd\r"
expect {
    -ex $cwd { pass "escape: Up-arrow swallowed, 'pwd' still runs clean" }
    timeout  { fail "escape: Up-arrow swallowed" "arrow likely corrupted the buffer" }
}
shutdown

# --- an unterminated quote triggers the continuation prompt -----------------
# Kept flat (not a nested expect): expect blocks nested inside another
# expect's action body don't match reliably here.

boot
send "echo 'hi\r"
set saw_prompt 0
expect {
    -ex "> " { set saw_prompt 1 }
    timeout  {}
}
if {$saw_prompt} {
    send "there'\r"
    expect {
        -ex "hi\r\nthere" { pass "continuation: multi-line quote joins with a newline" }
        timeout { fail "continuation: multi-line quote" "joined output not seen" }
    }
} else {
    fail "continuation: multi-line quote" "no '> ' continuation prompt appeared"
}
shutdown

# --- PATH executable completion ---------------------------------------------
# Mirrors the codecrafters scenario: create a custom executable in a tempdir,
# put that dir on PATH, then verify `custom<TAB>` completes to the executable.
# PATH is restored to "" afterward so the remaining tests stay hermetic.

# Restore the host PATH briefly so mktemp/touch/chmod are findable…
set ::env(PATH) $orig_path
set tmp [exec mktemp -d]
exec touch "$tmp/custom_executable"
exec chmod +x "$tmp/custom_executable"
# …then point PATH at our tempdir for the actual shell test.
set ::env(PATH) $tmp

boot
send "custom\t"
expect {
    -ex "custom_executable " { pass "completion: PATH executable 'custom' + Tab -> 'custom_executable '" }
    timeout { fail "completion: PATH executable" "custom_executable not completed" }
}
shutdown

# Restore host PATH for cleanup, then go back to empty for remaining tests.
set ::env(PATH) $orig_path
exec rm -rf $tmp
set ::env(PATH) ""

# --- Ctrl-D on an empty line exits the shell --------------------------------

boot
send "\x04"
expect {
    eof     { pass "Ctrl-D on an empty line exits the shell" }
    timeout { fail "Ctrl-D on an empty line exits the shell" "shell did not exit" }
}
shutdown

# --- the `exit` builtin terminates the shell --------------------------------

boot
send "exit\r"
expect {
    eof     { pass "'exit' builtin terminates the shell" }
    timeout { fail "'exit' builtin terminates the shell" "shell did not exit" }
}
shutdown

# --- summary ----------------------------------------------------------------

puts ""
puts "  $passed passed, $failed failed"
exit [expr {$failed > 0 ? 1 : 0}]
